# =============================================================================
# BookingScraper Pro — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control — it contains secrets.
#
# Environment: Windows 11 (local deployment)
# Repository:  https://github.com/Aprendiz73/scrvIIpro26.git
# =============================================================================

# ─── DATABASE (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=booking_scraper

# ─── REDIS / MEMURAI (Windows Redis alternative) ─────────────────────────────
# Required for Celery broker and optional distributed _active_ids tracking.
# Install Memurai for Windows: https://www.memurai.com/
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# Advanced Redis tuning (optional)
REDIS_SOCKET_TIMEOUT_S=2.0
REDIS_CONN_TIMEOUT_S=2.0
REDIS_MAX_CONNECTIONS=10
ACTIVE_ID_TTL_SECONDS=3600

# ─── API SECURITY ─────────────────────────────────────────────────────────────
# Leave empty to disable API key auth (development only).
# Set a strong random value for any networked deployment.
API_KEY=
# Allowed CORS origins (comma-separated). Use * for local dev ONLY.
CORS_ORIGINS=*

# ─── SCRAPER SETTINGS ─────────────────────────────────────────────────────────
# Languages to scrape (ISO 639-1 codes, comma-separated)
LANGUAGES_ENABLED=en,es,de,fr,it
DEFAULT_LANGUAGE=en
# Number of URLs per dispatch batch (max 10)
BATCH_SIZE=1
# Maximum retry attempts per URL
MAX_RETRIES=3
# Worker threads (1 = sequential, required when VPN_ENABLED=True)
SCRAPER_MAX_WORKERS=1
# Use Selenium/Brave browser (True) or CloudScraper HTTP client (False)
USE_SELENIUM=True
# Download hotel images to disk
DOWNLOAD_IMAGES=True

# ─── VPN (NordVPN — Windows only) ────────────────────────────────────────────
# Set VPN_ENABLED=True only if NordVPN is installed and authenticated.
VPN_ENABLED=False
# IMPORTANT: SCRAPER_MAX_WORKERS must be 1 when VPN_ENABLED=True
VPN_COUNTRIES=UK,US,CA,DE,FR,NL,IT,ES
VPN_ROTATE_EVERY_N=10
VPN_ROTATION_INTERVAL=50
VPN_FAILOVER_TIMEOUT_SECS=90
VPN_LOCK_TIMEOUT_SECONDS=30
VPN_IP_CHECK_TIMEOUT_SECONDS=8
# Circuit breaker: open after N consecutive VPN failures
VPN_FAILURE_THRESHOLD=5
# Cooldown period (seconds) when VPN circuit is open
VPN_COOLDOWN_SECONDS=300

# ─── REDIS CIRCUIT BREAKER (HIGH-002) ─────────────────────────────────────────
# Circuit breaker: open Redis CB after N consecutive ping failures
REDIS_FAILURE_THRESHOLD=5
# Time (seconds) Redis CB stays open before probing again (HALF-OPEN)
REDIS_COOLDOWN_SECONDS=60

# ─── ERROR HANDLING (HIGH-005) ────────────────────────────────────────────────
# Maximum characters stored in last_error / error_message DB columns.
# Changing this value requires a schema migration to resize VARCHAR columns.
MAX_ERROR_LEN=2000

# ─── CELERY TASK LIMITS (HIGH-013) ────────────────────────────────────────────
# Time limits for process_pending_urls Celery task.
# Increase only if hotels with many languages/images consistently time out.
CELERY_TASK_SOFT_TIME_LIMIT=150
CELERY_TASK_TIME_LIMIT=180

# ─── DISPATCHER ───────────────────────────────────────────────────────────────
# False = asyncio loop dispatcher (default, no Celery required)
# True  = Celery task queue (requires Redis for state sharing)
USE_CELERY_DISPATCHER=False
# Celery (only used when USE_CELERY_DISPATCHER=True)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_WORKER_POOL=solo
CELERY_WORKER_CONCURRENCY=1

# ─── FILE PATHS ───────────────────────────────────────────────────────────────
# Leave empty to use default: <repo_root>/data/
# Override only if you want data stored elsewhere.
# BASE_DATA_PATH=C:\BookingScraper\data
# IMAGES_PATH=C:\BookingScraper\data\images
# EXPORTS_PATH=C:\BookingScraper\data\exports
# LOGS_PATH=C:\BookingScraper\data\logs

# ─── BROWSER (Brave) ──────────────────────────────────────────────────────────
# Leave empty for auto-detection of Brave installation.
# BROWSER_BRAVE_PATH=C:\Program Files\BraveSoftware\Brave-Browser\Application\brave.exe

# ─── PERFORMANCE TUNING ───────────────────────────────────────────────────────
# Rate limit window in seconds
RATE_LIMIT_WINDOW_SECONDS=60
# Max requests per window per IP
RATE_LIMIT_MAX_REQUESTS=120
# Max requests per minute to /stats endpoint
STATS_RATE_LIMIT=10
# Statement timeout for OLTP queries (ms)
STMT_TIMEOUT_OLTP_MS=30000
# Statement timeout for OLAP/export queries (ms)
STMT_TIMEOUT_OLAP_MS=300000
# Log queries slower than this (ms)
SLOW_QUERY_THRESHOLD_MS=2000

# ─── UVICORN STARTUP (recommended) ────────────────────────────────────────────
# [FIX ERR-ARCH-004] Request timeout and concurrency limits for uvicorn.
# Run the app with these flags to prevent slow-client resource exhaustion:
#
#   uvicorn app.main:app --host 0.0.0.0 --port 8000 \
#     --timeout-keep-alive 30 --limit-concurrency 50
#
# Or define as environment variable used by start_services.bat:
UVICORN_TIMEOUT_KEEP_ALIVE=30
UVICORN_LIMIT_CONCURRENCY=50
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

# ─── LOGGING ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Set DEBUG=true to enable SQLAlchemy SQL echo (WARNING: logs all queries)
DEBUG=false

# ─── DEBUG HTML CLEANUP (CRIT-007) ────────────────────────────────────────────
# Delete debug HTML files older than this many hours
DEBUG_HTML_MAX_AGE_HOURS=24
# Cap total debug HTML directory size (MB); oldest files evicted first
DEBUG_HTML_MAX_TOTAL_MB=500
