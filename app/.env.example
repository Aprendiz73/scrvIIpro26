# ─────────────────────────────────────────────────────────────────────────────
# BookingScraper Pro — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control (it is in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── SECURITY ─────────────────────────────────────────────────────────────────
# API key for protected endpoints (e.g., /scraping/force-now).
# Leave empty to disable protection (development only — not for production).
API_KEY=change-me-to-a-strong-random-key

# ── APPLICATION ──────────────────────────────────────────────────────────────
APP_NAME=Booking Scraper Pro
APP_VERSION=6.0.0
DEBUG=False
LOG_LEVEL=INFO

# ── POSTGRESQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
# [REQUIRED] Must not be empty — application refuses to start if blank.
DB_PASSWORD=your_strong_postgres_password_here
DB_NAME=booking_scraper

# PostgreSQL connection pool (per-process)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
# Hard cap across all processes (FastAPI + Celery). Must not exceed PG max_connections.
DB_TOTAL_HARD_CAP=50

# ── REDIS / MEMURAI ──────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Circuit breaker thresholds for Redis
REDIS_FAILURE_THRESHOLD=5
REDIS_COOLDOWN_SECONDS=60

# ── CELERY ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# MUST remain 1 on Windows (solo pool — no fork support).
CELERY_WORKER_CONCURRENCY=1
# Task time limits (seconds)
CELERY_TASK_SOFT_TIME_LIMIT=150
CELERY_TASK_TIME_LIMIT=180

# ── VPN ──────────────────────────────────────────────────────────────────────
# Set to True only if NordVPN is installed and configured.
VPN_ENABLED=False
# Comma-separated ISO country codes. First entry is preferred.
VPN_COUNTRIES=UK,US,CA,DE,FR,NL,IT,ES
# Rotate VPN every N hotels scraped.
VPN_ROTATE_EVERY_N=10
# Failover timeout in seconds before entering degraded mode.
VPN_FAILOVER_TIMEOUT_SECS=90
# Circuit breaker for VPN
VPN_FAILURE_THRESHOLD=5
VPN_COOLDOWN_SECONDS=300

# ── SCRAPING ─────────────────────────────────────────────────────────────────
# Headless browser: True recommended for background operation.
HEADLESS_BROWSER=True
BROWSER_TIMEOUT=30
PAGE_LOAD_WAIT=5
SCROLL_ITERATIONS=3
MAX_RETRIES=3
RETRY_DELAY=60

# Delay between requests (seconds, random in [MIN, MAX])
MIN_REQUEST_DELAY=2.0
MAX_REQUEST_DELAY=5.0

# False=CloudScraper (faster), True=Selenium (for JS-heavy pages)
USE_SELENIUM=False

# Max concurrent scraping threads.
# MUST be 1 when VPN_ENABLED=True.
# Max 4 for local Windows 11 (network saturation risk above 4).
SCRAPER_MAX_WORKERS=1

# Watchdog interval (seconds) — detects Windows screen-lock suspension.
WATCHDOG_INTERVAL_SECS=120

# Executor graceful shutdown timeout (seconds) — how long to wait for in-flight
# tasks before force-cancelling them. Increase if scraping tasks are long.
EXECUTOR_SHUTDOWN_TIMEOUT_SECS=30

# ── BROWSER PATHS ────────────────────────────────────────────────────────────
# Leave empty to use auto-detected default paths.
# Windows example: C:\Program Files\BraveSoftware\Brave-Browser\Application\brave.exe
BROWSER_BRAVE_PATH=
BROWSER_OPERA_PATH=
BROWSER_CHROME_PATH=
BROWSER_EDGE_PATH=

# ── LANGUAGES ────────────────────────────────────────────────────────────────
# Comma-separated ISO 639-1 codes.
LANGUAGES_ENABLED=en,es,de,fr,it
DEFAULT_LANGUAGE=en

# ── IMAGES ───────────────────────────────────────────────────────────────────
DOWNLOAD_IMAGES=True
IMAGE_QUALITY=85
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1080
MAX_IMAGE_WORKERS=5

# ── BATCH ────────────────────────────────────────────────────────────────────
# Number of URLs to dispatch per cycle. Range: [1, 10].
BATCH_SIZE=5
MAX_CONCURRENT_TASKS=3

# ── DATA PATHS ────────────────────────────────────────────────────────────────
# Override default paths (relative to project root) if needed.
# Windows examples:
# BASE_DATA_PATH=C:\BookingScraper\data
# IMAGES_PATH=C:\BookingScraper\data\images
# EXPORTS_PATH=C:\BookingScraper\data\exports
# LOGS_PATH=C:\BookingScraper\data\logs

# ── DEBUG HTML CLEANUP ───────────────────────────────────────────────────────
# Delete debug HTML files older than N hours.
DEBUG_HTML_MAX_AGE_HOURS=24
# Delete oldest files when debug directory exceeds N MB.
DEBUG_HTML_MAX_TOTAL_MB=500

# ── LOGGING ──────────────────────────────────────────────────────────────────
# Maximum error message length stored in DB (last_error column = VARCHAR(2000)).
MAX_ERROR_LEN=2000

# ── DISPATCHER ───────────────────────────────────────────────────────────────
# False = asyncio auto-dispatch (recommended for Windows 11 local).
# True = Celery dispatcher (requires Redis for correct inter-process state).
USE_CELERY_DISPATCHER=False

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API.
# NEVER use * — see SEC-002 fix notes.
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── RATE LIMITING ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120

# ── EXPORT ───────────────────────────────────────────────────────────────────
EXPORT_FORMATS=csv,json,excel
