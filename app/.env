# =============================================================================
# BookingScraper Pro v6.0 — .env Configuration
# =============================================================================
#
# USAGE:
#   Copy this file to the project root as ".env" and fill in all values
#   marked with <CHANGE_THIS>.
#   NEVER commit .env with real credentials to version control.
#   Add ".env" to .gitignore.
#
# SECURITY:
#   In production use a secrets manager (HashiCorp Vault, AWS Secrets Manager,
#   Azure Key Vault) and inject values at runtime rather than storing them here.
#
# REQUIRED fields must be set before the application will start.
# OPTIONAL fields have safe defaults and can be left unchanged for local dev.
#
# Generate a secure API key:
#   python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================


# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME=BookingScraper Pro
APP_VERSION=6.0.0
APP_HOST=0.0.0.0
APP_PORT=8000

# Timezone (used by Celery beat schedule and log timestamps)
TZ=UTC

# Python I/O encoding — required on Windows for UTF-8 hotel names
PYTHONIOENCODING=utf-8


# =============================================================================
# DATABASE — PostgreSQL
# =============================================================================
# REQUIRED: Change host/user/password before first run.
DB_HOST=localhost
DB_PORT=5432
DB_USER=scraper_app
DB_PASSWORD=<CHANGE_THIS>
DB_NAME=booking_scraper

# Connection pool settings (tune per server capacity)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Full connection URL (auto-constructed from above if left blank)
# DATABASE_URL=postgresql+psycopg://scraper_app:<CHANGE_THIS>@localhost:5432/booking_scraper


# =============================================================================
# REDIS — Broker & Result Backend
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Full URLs used by Celery (override the individual fields above if needed)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1


# =============================================================================
# CELERY
# =============================================================================
# WINDOWS CRITICAL: pool MUST be 'solo' — Windows has no fork() support.
# Linux/macOS: 'prefork' (default) or 'gevent' for I/O-bound tasks.
CELERY_WORKER_POOL=solo
CELERY_WORKER_CONCURRENCY=1

# Flower monitoring UI (optional — start with: celery flower -A app.tasks)
FLOWER_PORT=5555
FLOWER_USER=admin
FLOWER_PASSWORD=<CHANGE_THIS>


# =============================================================================
# SCRAPER — Core Settings
# =============================================================================
# Worker threads for batch dispatch
SCRAPER_MAX_WORKERS=1

# Batch size per dispatch cycle (every 30 seconds)
BATCH_SIZE=5

# Request delay range (seconds) — randomised between MIN and MAX
MIN_REQUEST_DELAY=2.0
MAX_REQUEST_DELAY=5.0

# Browser timeout (seconds)
BROWSER_TIMEOUT=30

# Selenium page-load wait after navigation (seconds)
PAGE_LOAD_WAIT=3

# Max retry attempts per URL before marking as 'failed'
MAX_RETRIES=3

# Delay between retries (seconds)
RETRY_DELAY=60

# Use Selenium (True) or CloudScraper (False) as primary backend
USE_SELENIUM=False

# Use Celery for background dispatch (True) or built-in asyncio dispatcher (False)
USE_CELERY_DISPATCHER=False

# Maximum concurrent Celery tasks
MAX_CONCURRENT_TASKS=3

# Watchdog interval: checks process health / screen-lock keep-alive (seconds)
WATCHDOG_INTERVAL_SECS=30


# =============================================================================
# LANGUAGES
# =============================================================================
# Comma-separated ISO 639-1 codes. Must match Booking.com supported languages.
# Supported: en, es, de, fr, it, pt, nl, ru
LANGUAGES_ENABLED=en,es,de,fr,it


# =============================================================================
# BROWSER PATHS — Selenium WebDriver
# =============================================================================
# Leave blank to use system PATH / WebDriver Manager auto-download.
# Windows examples:
#   BROWSER_BRAVE_PATH=C:\Program Files\BraveSoftware\Brave-Browser\Application\brave.exe
#   BROWSER_CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
BROWSER_BRAVE_PATH=
BROWSER_CHROME_PATH=
BROWSER_EDGE_PATH=
BROWSER_OPERA_PATH=


# =============================================================================
# VPN — NordVPN (Windows CLI)
# =============================================================================
VPN_ENABLED=False

# Connection method: auto | cli | registry
VPN_METHOD=auto

# Comma-separated NordVPN country codes
VPN_COUNTRIES=UK,US,CA,DE,FR,NL,IT,ES

# Rotate VPN after N hotels scraped
VPN_ROTATE_EVERY_N=10

# Rotate VPN after N consecutive failures
VPN_ROTATION_INTERVAL=50

# Seconds to wait for VPN connection before failover (degraded mode)
VPN_FAILOVER_TIMEOUT_SECS=90


# =============================================================================
# IMAGES
# =============================================================================
# Download hotel images to disk (True/False)
DOWNLOAD_IMAGES=True

# Image storage directory (relative to project root or absolute path)
IMAGES_PATH=./data/images

# Maximum parallel image download threads
MAX_IMAGE_WORKERS=5

# JPEG quality (1–100)
IMAGE_QUALITY=85

# Maximum image dimensions after resize (pixels)
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1080


# =============================================================================
# DATA / EXPORT
# =============================================================================
# Base directory for all scraped data (images, status files, exports)
# Windows: BASE_DATA_PATH=C:\BookingScraper\data
# Linux:   BASE_DATA_PATH=/opt/bookingscraper/data
BASE_DATA_PATH=./data

# Comma-separated export formats: csv, excel, json
EXPORT_FORMATS=csv,excel,json


# =============================================================================
# API / SECURITY
# =============================================================================
# API key for protected endpoints (e.g. /scraping/force-now).
# Leave empty to run without authentication (local dev only).
# REQUIRED in production: set to a strong random value.
API_KEY=<CHANGE_THIS>

# Debug mode — enables detailed error responses (NEVER True in production)
DEBUG=False

# Enable Swagger/ReDoc docs (disable in production)
API_DOCS_ENABLED=True

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080


# =============================================================================
# LOGGING
# =============================================================================
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO




# =============================================================================
# SCRAPER — Advanced Settings
# =============================================================================
# Run browser in headless mode (True = no visible window). Always True in prod.
HEADLESS_BROWSER=True

# Number of page scroll iterations for lazy-loaded content
SCROLL_ITERATIONS=3

# Default fallback language when no language is specified
DEFAULT_LANGUAGE=en


# =============================================================================
# DATA PATHS — Exports & Logs
# =============================================================================
EXPORTS_PATH=./data/exports
LOGS_PATH=./data/logs
# =============================================================================
# NOTIFICATIONS (OPTIONAL)
# =============================================================================
# Telegram — send alerts on failures / completion
TELEGRAM_ENABLED=False
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMTP — email alerts
SMTP_ENABLED=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=bookingscraper@example.com

# =============================================================================
# v21 — Enterprise Audit Fixes (2026-03-04)
# =============================================================================

# [FIX ARCH-002] Redis URL for distributed _active_ids (multi-worker support).
# Set to enable horizontal scaling. Leave empty for single-process deployment.
# Format: redis://[password@]host:port/db
REDIS_URL=redis://localhost:6379/0

# TTL (seconds) for Redis URL claim keys.
# Prevents stale keys if a worker crashes without releasing a claim.
ACTIVE_ID_TTL_SECONDS=3600

# [FIX CONC-002] VPN circuit breaker thresholds.
# After VPN_FAILURE_THRESHOLD consecutive failures, VPN is bypassed for
# VPN_COOLDOWN_SECONDS seconds (degraded mode — scraping continues without VPN).
VPN_FAILURE_THRESHOLD=5
VPN_COOLDOWN_SECONDS=300

# [FIX SEC-006] Rate limit for the /stats endpoint (requests/minute per IP).
STATS_RATE_LIMIT=10

# [FIX DB-007] Statement timeout — OLTP sessions (ms). Default: 30 seconds.
STMT_TIMEOUT_OLTP_MS=30000

# [FIX DB-007] Statement timeout — OLAP/analytics sessions (ms). Default: 300 seconds.
STMT_TIMEOUT_OLAP_MS=300000

# [FIX CONC-006] Slow query logging threshold (ms).
# Queries exceeding this duration are logged as warnings.
SLOW_QUERY_THRESHOLD_MS=2000
