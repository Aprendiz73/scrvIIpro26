# ============================================================================
# .env — BookingScraper Pro v48  |  APLICADO EN: C:\BookingScraper\.env
# ============================================================================

# ── Seguridad ─────────────────────────────────────────────────────────────────
# FIX-ENV-001: SECRET_KEY reemplazada con clave real de 64 chars.
#   El placeholder anterior ("REEMPLAZA_CON...") NO era detectado por
#   config.py como inseguro (solo detecta la cadena exacta
#   "change-this-to-a-random-secret-key"). El sistema arrancaba con una
#   clave predecible, exponiendo tokens JWT a falsificación.
#   Para regenerar: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=BmO2g3ZfOINpzV-K02XtB3PlUJI9qzmiSNWc2ZbrRYQ2p6IZFQQI8-P4qHIfpi_M
API_KEY=
REQUIRE_API_KEY=false

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bookingscraper
DB_USER=postgres
DB_PASSWORD=cambiar_clave_postgresSQL
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ── Redis / Memurai ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Scraper ───────────────────────────────────────────────────────────────────
SCRAPER_MAX_WORKERS=2
SCRAPER_REQUEST_TIMEOUT=30
SCRAPER_RETRY_DELAY=2.0
MAX_RETRIES=3
MAX_LANG_RETRIES=3

# ── VPN — NordVPN v7.57.4.0 ───────────────────────────────────────────────────
VPN_ENABLED=true

VPN_COUNTRIES=Spain,Germany,France,Netherlands,Italy,United_Kingdom,Canada,Sweden

# Rotar IP cada 50 segundos para evitar bloqueos.
VPN_ROTATION_INTERVAL=50

# ── Browser / Selenium ────────────────────────────────────────────────────────
# false → ventana Brave VISIBLE en escritorio (modo test/debug)
# true  → sin ventana, modo produccion
HEADLESS_BROWSER=false

# ── Idiomas habilitados ───────────────────────────────────────────────────────
ENABLED_LANGUAGES=es,en,de,fr,it,nl,pt

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false
DEBUG_HTML_SAVE=false
DEBUG_HTML_MAX_AGE_HOURS=24
