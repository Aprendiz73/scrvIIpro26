# =============================================================================
# BookingScraper Pro v6.0 — Environment Configuration
# =============================================================================
#
# USAGE:
#   Copy this file to the project root as ".env" and fill in all values
#   marked with  <CHANGE_THIS>.
#
# SECURITY:
#   - Never commit this file to version control.
#   - Add ".env" to your .gitignore.
#   - In production use a secrets manager (HashiCorp Vault, AWS Secrets Manager,
#     Azure Key Vault) and inject values at runtime.
#
# REQUIRED fields must be set before the application will start.
# OPTIONAL fields have safe defaults and can be left unchanged for local dev.
# =============================================================================


# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME=Booking Scraper Pro
APP_VERSION=6.0.0

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# =============================================================================
# DATABASE — PostgreSQL  (REQUIRED)
# =============================================================================
# psycopg3 driver — connection string is built as:
#   postgresql+psycopg://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>

DB_HOST=localhost
DB_PORT=5432
DB_USER=scraper_app
# REQUIRED — application will refuse to start if empty
DB_PASSWORD=<CHANGE_THIS>
DB_NAME=booking_scraper

# Connection pool (tune based on PostgreSQL max_connections setting)
# Recommended: (max_connections - 5) / number_of_app_instances
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800


# =============================================================================
# REDIS  (REQUIRED — used by Celery broker and result backend)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Leave empty if Redis has no password (local dev)
REDIS_PASSWORD=

# Celery queues use separate Redis DBs to avoid key collisions
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Number of Celery worker processes.
# Windows MUST use 1 (solo pool — multiprocessing is not supported on Windows).
CELERY_WORKER_CONCURRENCY=1


# =============================================================================
# SCRAPING ENGINE
# =============================================================================

# Maximum concurrent scraping workers (ThreadPoolExecutor)
# WARNING: increasing this without lowering VPN_ROTATE_EVERY_N risks IP bans.
SCRAPER_MAX_WORKERS=1

# Delay between requests (seconds) — randomised between MIN and MAX
MIN_REQUEST_DELAY=2.0
MAX_REQUEST_DELAY=5.0

# Per-page browser timeout (seconds)
BROWSER_TIMEOUT=30

# Global retry policy
MAX_RETRIES=3
RETRY_DELAY=60

# Languages to scrape — comma-separated ISO 639-1 codes (2 letters each)
# Valid examples: en,es,de,fr,it  |  en  |  en,de
LANGUAGES_ENABLED=en,es,de,fr,it

# Use Celery for task dispatch (True) or asyncio auto-dispatch (False)
USE_CELERY_DISPATCHER=False

# Maximum simultaneous async tasks (asyncio path)
MAX_CONCURRENT_TASKS=3


# =============================================================================
# BROWSER PATHS — Windows 11
# Leave empty to use the built-in auto-detection list in scraper.py.
# Provide absolute paths only if auto-detection fails on your machine.
# =============================================================================
# Example: BROWSER_BRAVE_PATH=C:\Program Files\BraveSoftware\Brave-Browser\Application\brave.exe
BROWSER_BRAVE_PATH=
BROWSER_CHROME_PATH=
BROWSER_EDGE_PATH=
BROWSER_OPERA_PATH=


# =============================================================================
# VPN — NordVPN  (OPTIONAL)
# =============================================================================
# Set VPN_ENABLED=True to activate IP rotation.
# The application starts normally when False (useful for local development).
VPN_ENABLED=False

# Preferred exit countries — tried in order on each rotation.
# Format: comma-separated NordVPN country codes.
VPN_COUNTRIES=UK,US,CA,DE,FR,NL,IT,ES

# Rotate VPN after this many successful requests
VPN_ROTATE_EVERY_N=10

# Maximum requests before a forced rotation (safety ceiling)
VPN_ROTATION_INTERVAL=50

# Seconds to wait for VPN reconnection before failing over
VPN_FAILOVER_TIMEOUT_SECS=90


# =============================================================================
# IMAGE PROCESSING
# =============================================================================
# JPEG quality for saved images (1-95)
IMAGE_QUALITY=85

# Maximum image dimensions (pixels) — larger images are resized on download
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1080

# Concurrent image download threads
MAX_IMAGE_WORKERS=5


# =============================================================================
# DATA PATHS — Windows 11
# Use double backslashes (\\) or forward slashes (/) on Windows.
# Defaults are relative to the project root.
# =============================================================================
# Windows example: BASE_DATA_PATH=C:\\BookingScraper\\data
BASE_DATA_PATH=./data
IMAGES_PATH=./data/images
EXPORTS_PATH=./data/exports
LOGS_PATH=./data/logs


# =============================================================================
# EXPORT
# =============================================================================
# Supported formats: csv, json, excel  (comma-separated)
EXPORT_FORMATS=csv,json,excel


# =============================================================================
# API SECURITY  (REQUIRED for production)
# =============================================================================
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<CHANGE_THIS>

# API key for protected endpoints (header: X-API-Key)
API_KEY=<CHANGE_THIS>

# Allowed CORS origins — comma-separated URLs
# Use * only in development, never in production.
CORS_ORIGINS=http://localhost:3000,http://localhost:8000


# =============================================================================
# SCRAPING BEHAVIOUR — ADVANCED
# =============================================================================
# Default language when none is specified
DEFAULT_LANGUAGE=en

# Download hotel images to disk (True) or store only URLs (False)
DOWNLOAD_IMAGES=True

# Use Selenium WebDriver for scraping (True) or CloudScraper first (False)
USE_SELENIUM=False

# Run browser in headless mode — always True in production
# Set False only for local debugging to see the browser window
HEADLESS_BROWSER=True

# Seconds to wait after page load before extracting content
PAGE_LOAD_WAIT=5

# Number of scroll iterations to trigger lazy-loaded content
SCROLL_ITERATIONS=3

# Number of URLs processed per task batch
BATCH_SIZE=5

# Seconds between watchdog health checks
WATCHDOG_INTERVAL_SECS=120


# =============================================================================
# FASTAPI / UVICORN
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# Enable Swagger UI (/docs) and ReDoc (/redoc) — disable in production
API_DOCS_ENABLED=True

# Enable debug mode — NEVER True in production
DEBUG=False
